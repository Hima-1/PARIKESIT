/build/
/coverage/
/nul


# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio / Gradle
/android/.gradle/
/android/local.properties
/android/app/debug
/android/app/profile
/android/app/release

# Android secrets / signing
# File Firebase Android dan signing tetap release-only, tidak masuk Git.
/android/app/google-services.json
/android/app/*.keystore
/android/key.properties
